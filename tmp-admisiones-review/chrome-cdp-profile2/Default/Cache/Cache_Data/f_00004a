                  <div class="adm-action-row">
                    <button class="adm-button is-primary" data-action="open-topic" data-area-id="${escapeHtml(currentQuestion.areaId)}" data-topic-id="${escapeHtml(currentQuestion.topicId)}">Abrir microlección</button>
                    ${isSimulator ? '<button class="adm-button is-ghost" data-action="go-screen" data-screen="practice">Reforzar con práctica</button>' : ''}
                  </div>
                </div>
              ` : `
                <div class="adm-note-box">
                  ${allAnswered ? (isSimulator ? 'Ya puedes cerrar tu simulador y ver el resultado.' : 'Ya puedes calificar la práctica.') : 'Te faltan respuestas antes de calificar.'}
