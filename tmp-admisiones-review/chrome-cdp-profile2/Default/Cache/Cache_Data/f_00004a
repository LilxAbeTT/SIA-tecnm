    function renderActiveScreen(metrics) {
      if (_ui.screen === 'learn') return renderStudyScreen();
      if (_ui.screen === 'topic') return renderTopicDetail();
      if (_ui.screen === 'practice') {
        return _ui.quizQuestions.length ? renderPracticeRun() : renderPracticeHub(metrics);
      }
      if (_ui.screen === 'simulator') {
        return _ui.quizQuestions.length ? renderPracticeRun() : renderSimulatorScreen(metrics);
      }
      if (_ui.screen === 'info') return renderInfoScreen();
      return renderHomeScreen(metrics);
    }

    function render() {
      if (!_root) return;
      ensureFocusArea();
      const metrics = computeMetrics();
      const navScreen = getNavScreen();
      const showHero = navScreen === 'home';
      _root.classList.add('admisiones-public-page');
      _root.innerHTML = `
        <div class="adm-shell">
          ${renderTopNav(metrics)}
          ${showHero ? renderHeader(metrics) : ''}
          <div class="adm-app-layout is-single">
            <main class="adm-content">
              ${renderActiveScreen(metrics)}
            </main>
          </div>
          <p class="adm-footer-note">Este espacio adapta la guía oficial EVALUATEC 2026 para que estudies con una ruta clara: aprende, practica, simula y refuerza sólo lo que te falta dominar.</p>
        </div>
      `;
    }

    function handleClick(event) {
      const target = event.target.closest('[data-action]');
      if (!target) return;

      const action = target.dataset.action;
      const areaId = target.dataset.areaId || '';
      const topicId = target.dataset.topicId || '';
      const careerId = target.dataset.careerId || '';
      const screen = target.dataset.screen || '';
      const questionIndex = Number(target.dataset.questionIndex);
      const stepIndex = Number(target.dataset.stepIndex);

      if (action === 'go-screen') {
        goToScreen(screen || 'home', { areaId: _ui.areaId || getPreferredAreaId() });
        return;
      }

      if (action === 'scroll-careers') {
        if (getNavScreen() !== 'home') {
          goToScreen('home', { areaId: _ui.areaId || getPreferredAreaId() });
          if (getNavScreen() !== 'home') return;
        }
        window.requestAnimationFrame(() => {
          document.getElementById('adm-careers')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        return;
      }

      if (action === 'select-career') {
        if (!confirmDiscardPracticeIfNeeded()) return;
        const routeAreaIds = CareerPlanner.getAreasForCareer(careerId);
        GuestStore.patch({ selectedCareer: careerId, selectedAreas: routeAreaIds });
        _ui = {
          ...defaultUiState(),
          screen: 'home',
          areaId: routeAreaIds[0] || getPreferredAreaId()
        };
        render();
        return;
      }

      if (action === 'clear-career') {
        if (!confirmDiscardPracticeIfNeeded()) return;
        GuestStore.patch({ selectedCareer: '', selectedAreas: [] });
        _ui = {
          ...defaultUiState(),
          screen: 'home',
          areaId: getOrderedAreas()[0]?.id || ''
        };
        render();
        return;
      }

      if (action === 'focus-area') {
        if (!confirmDiscardPracticeIfNeeded()) return;
        _ui = {
          ...defaultUiState(),
          screen: 'learn',
          areaId
        };
        render();
        return;
      }

      if (action === 'clear-search') {
        _ui.search = '';
        render();
        return;
      }

      if (action === 'open-topic') {
        if ((_ui.screen === 'practice' || _ui.screen === 'simulator') && !_ui.quizSubmitted && !confirmDiscardPracticeIfNeeded()) return;
        _ui = {
          ...defaultUiState(),
          screen: 'topic',
          areaId,
          topicId,
          lessonStep: 0
        };
        setLastVisited({ kind: 'topic', areaId, topicId, lessonStep: 0, title: getTopic(areaId, topicId)?.title || '' });
        render();
        return;
      }

      if (action === 'toggle-bookmark') {
        GuestStore.toggleBookmark(getTopicKey(areaId, topicId));
        render();
        return;
      }

      if (action === 'mark-topic-studied' || action === 'lesson-mastered') {
        GuestStore.updateTopic(getTopicKey(areaId, topicId), { studied: true });
        const { next } = getTopicNeighbors(areaId, topicId);
        if (action === 'lesson-mastered' && next) {
          _ui = {
            ...defaultUiState(),
            screen: 'topic',
            areaId,
            topicId: next.id,
            lessonStep: 0
          };
          setLastVisited({ kind: 'topic', areaId, topicId: next.id, lessonStep: 0, title: next.title });
        } else {
          setLastVisited({ kind: 'topic', areaId, topicId, lessonStep: _ui.lessonStep || 0, title: getTopic(areaId, topicId)?.title || '' });
        }
        render();
        return;
      }

      if (action === 'start-area-practice') {
        if ((_ui.screen === 'practice' || _ui.screen === 'simulator') && !confirmDiscardPracticeIfNeeded()) return;
        startAssessment({
          screen: 'practice',
          scope: 'area',
          areaId,
          quizMode: 'guided',
          quizTitle: `Práctica de ${getArea(areaId)?.title || 'área'}`,
          quizDescription: 'Práctica guiada con retroalimentación inmediata.',
          quizSuggestedMinutes: 15,
          quizId: `area-${areaId}`,
          questions: PracticeEngine.buildAreaQuiz(areaId),
          lastVisited: { kind: 'practice', scope: 'area', areaId }
        });
        return;
      }

      if (action === 'start-topic-practice') {
        if ((_ui.screen === 'practice' || _ui.screen === 'simulator') && !confirmDiscardPracticeIfNeeded()) return;
        const topic = getTopic(areaId, topicId);
        startAssessment({
          screen: 'practice',
          scope: 'topic',
          areaId,
          topicId,
          quizMode: 'guided',
          quizTitle: `Práctica guiada: ${topic?.title || 'tema'}`,
          quizDescription: 'Refuerza el mismo subtema con ayuda inmediata.',
          quizSuggestedMinutes: 8,
          quizId: `topic-${areaId}-${topicId}`,
          questions: PracticeEngine.buildTopicQuiz(areaId, topicId),
          lastVisited: { kind: 'practice', scope: 'topic', areaId, topicId }
        });
        return;
      }

      if (action === 'start-career-practice') {
        if (!_guest.selectedCareer) {
          window.showToast?.('Selecciona una carrera primero para armar una práctica mixta.', 'warning');
          return;
        }
        if ((_ui.screen === 'practice' || _ui.screen === 'simulator') && !confirmDiscardPracticeIfNeeded()) return;
        startAssessment({
          screen: 'practice',
          scope: 'career',
          quizMode: 'guided',
          quizTitle: 'Práctica mixta por carrera',
          quizDescription: 'Mezcla corta de tus bloques principales.',
          quizSuggestedMinutes: 20,
          quizId: `career-${_guest.selectedCareer}`,
          questions: PracticeEngine.buildCareerQuiz(_guest.selectedCareer),
          lastVisited: { kind: 'practice', scope: 'career', careerId: _guest.selectedCareer }
        });
        return;
      }

      if (action === 'start-weak-practice') {
        if ((_ui.screen === 'practice' || _ui.screen === 'simulator') && !confirmDiscardPracticeIfNeeded()) return;
        startAssessment({
          screen: 'practice',
          scope: 'weak',
          quizMode: 'guided',
          quizTitle: 'Refuerzo de errores',
          quizDescription: 'Ataca primero los temas que más te han costado.',
          quizSuggestedMinutes: 12,
          quizId: 'weak-topics',
          questions: PracticeEngine.buildWeakQuiz(),
          lastVisited: { kind: 'practice', scope: 'weak' }
        });
        return;
      }

      if (action === 'start-career-simulator') {
        if (!_guest.selectedCareer) {
          window.showToast?.('Selecciona una carrera primero para iniciar un simulador por carrera.', 'warning');
          return;
        }
        if ((_ui.screen === 'practice' || _ui.screen === 'simulator') && !confirmDiscardPracticeIfNeeded()) return;
        startAssessment({
          screen: 'simulator',
          scope: 'simulator-career',
          quizMode: 'simulator',
          quizTitle: 'Simulador por carrera',
          quizDescription: 'Resuelve sin ayuda y revisa el resultado al final.',
          quizSuggestedMinutes: 45,
          quizId: `simulator-career-${_guest.selectedCareer}`,
          questions: PracticeEngine.buildSimulatorQuiz({ careerId: _guest.selectedCareer, limit: 20 }),
          lastVisited: { kind: 'simulator', scope: 'simulator-career', careerId: _guest.selectedCareer }
        });
        return;
      }

      if (action === 'start-general-simulator') {
        if ((_ui.screen === 'practice' || _ui.screen === 'simulator') && !confirmDiscardPracticeIfNeeded()) return;
        startAssessment({
          screen: 'simulator',
          scope: 'simulator-general',
          quizMode: 'simulator',
          quizTitle: 'Simulador general',
          quizDescription: 'Mezcla corta para entrenar ritmo y concentración.',
          quizSuggestedMinutes: 40,
          quizId: 'simulator-general',
          questions: PracticeEngine.buildSimulatorQuiz({ limit: 20 }),
          lastVisited: { kind: 'simulator', scope: 'simulator-general' }
        });
        return;
      }

      if (action === 'set-lesson-step') {
        if (!Number.isNaN(stepIndex)) {
          _ui.lessonStep = Math.max(0, Math.min(getLessonSteps().length - 1, stepIndex));
          if (_ui.screen === 'topic') setLastVisited({ kind: 'topic', areaId: _ui.areaId, topicId: _ui.topicId, lessonStep: _ui.lessonStep, title: getTopic(_ui.areaId, _ui.topicId)?.title || '' });
          render();
        }
        return;
      }

      if (action === 'prev-lesson-step') {
        _ui.lessonStep = Math.max(0, Number(_ui.lessonStep || 0) - 1);
        setLastVisited({ kind: 'topic', areaId: _ui.areaId, topicId: _ui.topicId, lessonStep: _ui.lessonStep, title: getTopic(_ui.areaId, _ui.topicId)?.title || '' });
        render();
        return;
      }

      if (action === 'next-lesson-step') {
        _ui.lessonStep = Math.min(getLessonSteps().length - 1, Number(_ui.lessonStep || 0) + 1);
        setLastVisited({ kind: 'topic', areaId: _ui.areaId, topicId: _ui.topicId, lessonStep: _ui.lessonStep, title: getTopic(_ui.areaId, _ui.topicId)?.title || '' });
        render();
        return;
      }

      if (action === 'prev-question') {
        _ui.quizIndex = Math.max(0, _ui.quizIndex - 1);
        render();
        return;
      }

      if (action === 'next-question') {
        _ui.quizIndex = Math.min(_ui.quizQuestions.length - 1, _ui.quizIndex + 1);
        render();
        return;
      }

      if (action === 'jump-question') {
        if (!Number.isNaN(questionIndex)) {
          _ui.quizIndex = Math.max(0, Math.min(_ui.quizQuestions.length - 1, questionIndex));
          render();
        }
        return;
      }

      if (action === 'submit-practice') {
        const missing = _ui.quizQuestions.find((question) => !Object.prototype.hasOwnProperty.call(_ui.quizAnswers, question.id));
        if (missing) {
          window.showToast?.('Contesta todos los reactivos antes de calificar la práctica.', 'warning');
          return;
        }
        _ui.quizSubmitted = true;
        _ui.quizResult = PracticeEngine.grade(_ui.quizQuestions, _ui.quizAnswers);
        persistPracticeResult();
        render();
        return;
      }

      if (action === 'restart-practice') {
        const restored = restoreAssessmentFromLastVisited(_guest.lastVisited);
        if (restored) {
          _ui = restored;
          render();
        }
        return;
      }

      if (action === 'continue-progress') {
        if (_guest.lastVisited) {
          window.AdmisionesPublic.resumeGuestProgress();
          return;
        }
        if (!_guest.selectedCareer) {
          document.getElementById('adm-careers')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          return;
        }
        const nextTopic = getNextRecommendedTopic(getRouteAreaIds());
        if (nextTopic) {
          _ui = {
            ...defaultUiState(),
            screen: 'topic',
            areaId: nextTopic.areaId,
            topicId: nextTopic.id,
            lessonStep: 0
          };
          setLastVisited({ kind: 'topic', areaId: nextTopic.areaId, topicId: nextTopic.id, lessonStep: 0, title: nextTopic.title });
          render();
        }
        return;
      }

      if (action === 'reset-progress') {
        const confirmed = window.confirm('Se reiniciará el progreso local del invitado. ¿Deseas continuar?');
        if (confirmed) window.AdmisionesPublic.resetGuestProgress();
      }
    }

    function handleChange(event) {
      const target = event.target;
      if (!target || !target.dataset.action) return;

      if (target.dataset.action === 'set-micro-answer') {
        const topicKey = getTopicKey(target.dataset.areaId, target.dataset.topicId);
        const value = Number(target.value);
        _ui.microAnswers = { ..._ui.microAnswers, [topicKey]: value };
        const topic = getTopic(target.dataset.areaId, target.dataset.topicId);
        GuestStore.updateTopic(topicKey, { microPassed: value === topic.microPractice.correctIndex });
        render();
        return;
      }

      if (target.dataset.action === 'practice-answer') {
        _ui.quizAnswers = { ..._ui.quizAnswers, [target.dataset.questionId]: Number(target.value) };
      }
    }

    function handleInput(event) {
      const target = event.target;
      if (!target || !target.dataset.action) return;

      if (target.dataset.action === 'study-search') {
        _ui.search = target.value || '';
        if (_ui.screen !== 'learn') _ui.screen = 'learn';
        render();
      }
    }

    function persistPracticeResult() {
      if (!_ui.quizResult) return;

      const practiceResults = _guest.practiceResults || { scopes: {}, topicStats: {}, areaStats: {} };
      const takenAt = new Date().toISOString();
      const scopeId = _ui.quizId;
      const nextTopicStats = { ...practiceResults.topicStats };
      const nextAreaStats = { ...practiceResults.areaStats };
      const nextProgressByTopic = { ..._guest.progressByTopic };

      _ui.quizResult.items.forEach((item) => {
        const topicKey = getTopicKey(item.areaId, item.topicId);
        const currentTopic = nextTopicStats[topicKey] || { correct: 0, total: 0 };
        const currentArea = nextAreaStats[item.areaId] || { correct: 0, total: 0 };

        nextTopicStats[topicKey] = {
          correct: currentTopic.correct + (item.isCorrect ? 1 : 0),
          total: currentTopic.total + 1
        };
        nextAreaStats[item.areaId] = {
          correct: currentArea.correct + (item.isCorrect ? 1 : 0),
          total: currentArea.total + 1
        };

        nextProgressByTopic[topicKey] = {
          ...(nextProgressByTopic[topicKey] || {}),
          studied: item.isCorrect ? true : Boolean(nextProgressByTopic[topicKey]?.studied),
          updatedAt: takenAt
        };
      });

      GuestStore.patch({
        progressByTopic: nextProgressByTopic,
        practiceResults: {
          scopes: {
            ...practiceResults.scopes,
            [scopeId]: {
              percent: _ui.quizResult.percent,
              correct: _ui.quizResult.correct,
              total: _ui.quizResult.total,
              takenAt,
              scope: _ui.practiceScope,
              mode: _ui.quizMode,
              areaId: _ui.areaId || null,
              topicId: _ui.topicId || null,
              careerId: _guest.selectedCareer || null
            }
          },
          topicStats: nextTopicStats,
          areaStats: nextAreaStats
        }
      });
    }

    async function init(ctx, options = {}) {
      _ctx = ctx;
      ensureRoot();
      ensureStyles();
      _resources = await ContentRepo.load();
      _guest = GuestStore.load();
      hydrateSelectedAreas();
      _ui = defaultUiState();
      _ui.areaId = getPreferredAreaId();
      if (options.resume !== false) applyLastVisited();
      ensureFocusArea();
      bindEvents();
      render();
    }

    function resetGuestProgress() {
      _guest = GuestStore.reset();
      _ui = defaultUiState();
      _ui.areaId = getPreferredAreaId();
      render();
    }

    function resumeGuestProgress() {
      _guest = GuestStore.load();
      if (_guest.lastVisited) {
        applyLastVisited();
      } else {
        const nextTopic = _guest.selectedCareer ? getNextRecommendedTopic(getRouteAreaIds()) : null;
        if (nextTopic) {
          _ui = {
            ...defaultUiState(),
            screen: 'topic',
            areaId: nextTopic.areaId,
            topicId: nextTopic.id,
            lessonStep: 0
          };
        } else {
          _ui = {
            ...defaultUiState(),
            screen: _guest.selectedCareer ? 'learn' : 'home',
            areaId: getPreferredAreaId()
          };
        }
      }
      ensureFocusArea();
      render();
    }

    return {
      init,
      resetGuestProgress,
      resumeGuestProgress
    };
  })();
}
