    // [NEW ARCHITECTURE] Core & Components
    const localScripts = [
      '/config/departments.js',       // Config Global (Critical: Before App)
      '/services/firebase.js',        // Base SDK
      '/services/panic-service.js',   // Panic / SOS institutional flow
      '/utils/pdf-generator.js',      // Utils
